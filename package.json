{
  "name": "modern-jalali-datepicker",
  "version": "1.0.3",
  "description": "Modern Jalali (Persian) Date Picker with range selection, multiple dates, time picker and customizable themes.",
  "type": "module",

  "main": "./dist/modern-jalali-datepicker.umd.cjs",
  "module": "./dist/modern-jalali-datepicker.js",

  "exports": {
    ".": {
      "import": "./dist/modern-jalali-datepicker.js",
      "require": "./dist/modern-jalali-datepicker.umd.cjs"
    },
    "./style.css": "./dist//modern-jalali-datepicker.css"
  },

  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],

  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },

  "keywords": [
    "jalali",
    "persian",
    "datepicker",
    "calendar",
    "shamsi",
    "time-picker",
    "range-picker"
  ],

  "author": "YOUR_NAME",

  "license": "MIT",

  "repository": {
    "type": "git",
    "url": "https://github.com/mohammadhossein-motamedi/modern-jalali-datepicker.git"
  },

  "homepage": "https://github.com/mohammadhossein-motamedi/modern-jalali-datepicker",

  "bugs": {
    "url": "https://github.com/mohammadhossein-motamedi/modern-jalali-datepicker/issues"
  },

  "dependencies": {
    "jalaali-js": "^2.0.0"
  },

  "devDependencies": {
    "vite": "^8.1.0"
  }
}